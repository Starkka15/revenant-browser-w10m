@@ -11,6 +11,17 @@
 # sync across those files.
 #
 cmake_minimum_required(VERSION 3.12)
+
+# W10M/UWP (ARM32): build with NO compiler debug info. /Zi causes /MP PDB races at
+# WebCore scale (C1041), and /Z7 embeds debug into every .obj so the static
+# WebCore.lib archive exceeds the 32-bit 4GB image limit (LNK1248). CMP0141 NEW +
+# an empty format makes CMake emit no DebugInformationFormat at all.
+if (POLICY CMP0141)
+    cmake_policy(SET CMP0141 NEW)
+    set(CMAKE_POLICY_DEFAULT_CMP0141 NEW)
+endif ()
+set(CMAKE_MSVC_DEBUG_INFORMATION_FORMAT "")
+
 project(WebKit)
 
