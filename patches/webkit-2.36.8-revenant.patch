+    # C++/CX (/ZW) pulls in vccorlib.lib, which MUST be linked before msvcrt.lib or the linker
+    # errors LNK2038 (vccorlib_lib_should_be_specified_before_msvcrt_lib). The documented fix:
+    # /NODEFAULTLIB both, then relist them in the correct order (Release CRT).
+    target_link_options(WebCoreRenderShell PRIVATE
+        "/NODEFAULTLIB:vccorlib.lib" "/NODEFAULTLIB:msvcrt.lib" "vccorlib.lib" "msvcrt.lib")
+    # Emit a linker .map so we can resolve a runtime crash address (logged as an RVA off the
+    # module base) back to the exact WebCore function that null-dereferenced.
+    target_link_options(WebCoreRenderShell PRIVATE "/MAP")
+    # MAIN-THREAD STACK. We had no /STACK at all, so the UI thread ran on MSVC's DEFAULT 1MB
+    # reserve -- and that is the thread WebCore paints on. Every real WebKit port gives the main
+    # thread far more, because layout and paint are deeply recursive by construction:
+    # RenderLayer::paintLayer -> paintLayerContents -> paintList -> (child) paintLayer ..., once per
+    # nesting level, and cairo/SVG raster recurses on top of that. Ad-heavy pages nest hundreds of
+    # levels deep inside their <iframe srcdoc> trees.
+    #
+    # This is what the crash logs look like: the process VANISHES inside c3:updateBacking, mid-cairo
+    # raster, right after an about:srcdoc ad iframe attaches -- with no fault from an unfiltered
+    # all-thread vectored handler, no unhandled exception, no PLM notification, and 81MB of a 390MB
+    # cap. A stack overflow produces exactly that silence: the guard page blows and there is not
+    # enough stack left to run the handler that would have reported it.
+    # 16MB reserve is address space, not committed memory -- pages commit only as the stack grows.
+    target_link_options(WebCoreRenderShell PRIVATE "/STACK:16777216,131072")
+endif ()
+
 if (APPLE)
     set_target_properties(WebCore PROPERTIES LINK_FLAGS "-sub_library libobjc -umbrella WebKit -allowable_client WebCoreTestSupport -allowable_client WebKit2 -allowable_client WebKitLegacy")
 endif ()
