+    for (unsigned i = 0; i < n; ++i) {
+        char c = preview[i];
+        if (c == '\n' || c == '\r' || c == '\t') preview[i] = ' ';
+    }
+    char buf[320];
+    snprintf(buf, sizeof buf, "b64diag: %s FAIL len=%u firstNonLatin1Idx=%d cp=U+%04X preview=[%s]", which, len, firstNonLatin1, badCp, preview);
