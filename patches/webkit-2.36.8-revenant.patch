+bool IdleCallbackController::runIdleCallbacksWithDeadline(MonotonicTime deadline)
+{
+    if (!m_document || !m_document->frame())
+        return false;
+    if (m_idleRequestCallbacks.isEmpty() && m_runnableIdleCallbacks.isEmpty())
+        return false;
+
+    // Start an idle period: promote all currently-requested callbacks to runnable.
+    for (auto& request : m_idleRequestCallbacks)
+        m_runnableIdleCallbacks.append({ request.identifier, WTFMove(request.callback) });
+    m_idleRequestCallbacks.clear();
+
+    // Invoke runnable callbacks until the deadline is reached. Always run at least one so a page whose
+    // frames exceed the idle budget (heavy SPA under load) still makes forward progress instead of
+    // deferring forever. Each callback sees `deadline` via IdleDeadline and self-paces its work.
+    bool ranAny = false;
+    while (!m_runnableIdleCallbacks.isEmpty()) {
+        auto request = m_runnableIdleCallbacks.takeFirst();
+        auto idleDeadline = IdleDeadline::create(deadline);
+        request.callback->handleEvent(idleDeadline.get());
+        ranAny = true;
+        if (MonotonicTime::now() >= deadline)
+            break;
+    }
+    return ranAny;
+}
+
 } // namespace WebCore
