-bool PopupMenuWin::onGetObject(WPARAM wParam, LPARAM lParam, LRESULT& lResult)
-{
-    lResult = 0;
-
-    if (static_cast<LONG>(lParam) != OBJID_CLIENT)
-        return false;
-
-    if (!m_accessiblePopupMenu)
-        m_accessiblePopupMenu = new AccessiblePopupMenu(*this);
