+static void b64diag(const char* which, const String& s)
+{
+    CString u = s.utf8();
+    unsigned len = s.length();
+    int firstNonLatin1 = -1;
+    unsigned badCp = 0;
+    for (unsigned i = 0; i < len; ++i) {
